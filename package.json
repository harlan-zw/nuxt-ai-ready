{
  "name": "nuxt-ai-ready",
  "type": "module",
  "version": "0.6.3",
  "packageManager": "pnpm@10.28.0",
  "description": "Best practice AI & LLM discoverability for Nuxt sites.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "contributors": [
    "Harlan Wilton <harlan@harlanzw.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://nuxtseo.com/ai-ready",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt-seo-pro/nuxt-ai-ready.git"
  },
  "bugs": {
    "url": "https://github.com/nuxt-seo-pro/nuxt-ai-ready/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./mcp": {
      "types": "./mcp.d.ts",
      "import": "./dist/runtime/mcp.js"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist",
    "mcp.d.ts"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:minimal": "nuxi dev playground",
    "prepare:fixtures": "nuxi prepare playground && nuxi prepare playground && nuxi prepare test/fixtures/basic",
    "dev:build": "nuxi build playground",
    "dev:build:minimal": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && nuxi prepare playground",
    "dev:prepare:minimal": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && nuxi prepare playground",
    "release": "pnpm build && bumpp -x \"npx changelogen --output=CHANGELOG.md\"",
    "prepack": "pnpm run build",
    "test": "pnpm run prepare:fixtures && vitest",
    "test:unit": "vitest run --project=unit",
    "test:e2e": "pnpm run prepare:fixtures && vitest run --project=e2e",
    "typecheck": "nuxt typecheck",
    "test:attw": "attw --pack"
  },
  "peerDependencies": {
    "@nuxtjs/sitemap": "catalog:",
    "better-sqlite3": "catalog:"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@nuxt/kit": "catalog:",
    "consola": "catalog:",
    "db0": "catalog:",
    "defu": "catalog:",
    "mdream": "catalog:",
    "nuxt-site-config": "catalog:",
    "ofetch": "catalog:",
    "pathe": "catalog:",
    "pkg-types": "catalog:",
    "std-env": "catalog:",
    "ufo": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@arethetypeswrong/cli": "catalog:",
    "@headlessui/vue": "catalog:",
    "@nuxt/content": "catalog:",
    "@nuxt/devtools-ui-kit": "catalog:",
    "@nuxt/module-builder": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@nuxtjs/color-mode": "catalog:",
    "@nuxtjs/eslint-config-typescript": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@nuxtjs/mcp-toolkit": "catalog:",
    "@nuxtjs/robots": "catalog:",
    "@nuxtjs/sitemap": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "agents": "catalog:",
    "ai": "catalog:",
    "better-sqlite3": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "execa": "catalog:",
    "happy-dom": "catalog:",
    "nuxt": "catalog:",
    "nuxt-site-config": "catalog:",
    "playwright": "catalog:",
    "playwright-core": "catalog:",
    "postgres": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vue-tsc": "catalog:",
    "wrangler": "catalog:",
    "zod": "catalog:"
  },
  "resolutions": {
    "nuxt-ai-ready": "workspace:*"
  }
}
